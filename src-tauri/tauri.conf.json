{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WalkingMan",
  "version": "0.1.0",
  "identifier": "com.yeong.walkingman",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:61235",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "WalkingMan",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "WalkingMan Overlay",
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "focus": false,
        "width": 800,
        "height": 340
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
